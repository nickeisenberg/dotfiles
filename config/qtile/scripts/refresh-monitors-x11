#!/usr/bin/env bash

INTERNAL_PORT=$(
    xrandr | awk '$2=="connected" && $1 ~ /^eDP/ {print $1; exit}'
)

PORT_NAME=$(
    xrandr | awk '$2=="connected" && $1 ~ /^HDMI/ {print $1; exit}'
)

# Always start with the external monitor disabled.
if [[ -n "$PORT_NAME" ]]; then
    xrandr --output "$PORT_NAME" --off
fi

# Enable the laptop panel first and make it primary.
xrandr --output "$INTERNAL_PORT" --auto --primary

# Enable the external monitor if one is connected.
if [[ -n "$PORT_NAME" ]]; then
    xrandr \
        --output "$PORT_NAME" --auto \
        --above "$INTERNAL_PORT"
fi

sleep 0.5

feh --no-fehbg --bg-scale "$HOME/.config/qtile/assets/house-on-river.jpg"
